<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootView"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F8F8F8">

 <!--Display-->
    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:gravity="center_vertical"
        android:text="0"
        android:textSize="36sp"
        android:textStyle="bold"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp"/>

    <!--Buttons-->
    <GridLayout
        android:id="@+id/gridLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:layout_marginTop="16dp">

        <!--Row 1-->
        <Button android:text="7" style="@style/Theme.Calculator"/>
        <Button android:text="8" style="@style/Theme.Calculator"/>
        <Button android:text="9" style="@style/Theme.Calculator"/>
        <Button android:text="/" style="@style/Theme.Calculator"/>
        <!--Row 2-->
        <Button android:text="4" style="@style/Theme.Calculator"/>
        <Button android:text="5" style="@style/Theme.Calculator"/>
        <Button android:text="6" style="@style/Theme.Calculator"/>
        <Button android:text="*" style="@style/Theme.Calculator"/>
        <!--Row 3-->
        <Button android:text="1" style="@style/Theme.Calculator"/>
        <Button android:text="2" style="@style/Theme.Calculator"/>
        <Button android:text="3" style="@style/Theme.Calculator"/>
        <Button android:text="-" style="@style/Theme.Calculator"/>
        <!--Row 4-->
        <Button android:text="0" style="@style/Theme.Calculator"/>
        <Button android:text="C" style="@style/Theme.Calculator"/>
        <Button android:text="=" style="@style/Theme.Calculator"/>
        <Button android:text="+" style="@style/Theme.Calculator"/>

    </GridLayout>

</LinearLayout>